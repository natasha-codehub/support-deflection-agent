# Gemini API key — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Confidence thresholds (adjust these as the dial)
CONFIDENCE_HIGH=0.80
CONFIDENCE_MEDIUM=0.65

# Organisation context injected into system prompts
ORG_NAME=AcmeCo Industrial
ORG_DOMAIN=B2B industrial gas distribution

# CORS — set to your Vercel frontend URL in production
FRONTEND_URL=http://localhost:5173
